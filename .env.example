# Environment configuration for WETH Phase 1

# Database
DATABASE_URL="postgresql://weth:weth_pass@localhost:5432/weth_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Blockchain
# Replace this with your actual Sepolia RPC URL (e.g., Alchemy or Infura)
SEPOLIA_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY"

# Chain Configuration
CHAIN_ID="11155111"

# API Configuration
PORT="3000"

# Logging
# Valid values: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL="info"
